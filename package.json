  "description": "learning node express n more",
  "scripts": {
    "start": "node server.js",
    "build": "npm run build:js",
    "data:import": "node dev-data/data/import-dev-data.js --import",
    "data:delete": "node dev-data/data/import-dev-data.js --delete",
    "start:dev": "nodemon server.js",
    "start:prod": "set NODE_ENV=production && nodemon server.js",
    "debug": "ndb server.js",
    "watch:js": "parcel watch ./public/js/index.js --dist-dir ./public/bundle/",
    "build:js": "parcel build ./public/js/index.js --dist-dir ./public/bundle/"
  },
